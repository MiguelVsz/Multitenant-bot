# ========================================
# CONFIGURACIÓN DEL SERVIDOR
# ========================================
PORT=8080
LOG_LEVEL=info

# ========================================
# BASE DE DATOS (PostgreSQL)
# Formato: postgres://usuario:contraseña@host:puerto/nombre_db?sslmode=disable
# ========================================
DATABASE_URL=postgres://postgres:your_password@localhost:5432/go-bot?sslmode=disable

# ========================================
# REDIS
# Local:   redis://localhost:6379
# Upstash: rediss://default:your_token@your-endpoint.upstash.io:6379
# ========================================
REDIS_URL=rediss://default:your_token@your-endpoint.upstash.io:6379
SESSION_TTL_MINUTES=30

# ========================================
# CREDENCIALES DE META WHATSAPP BUSINESS
# Obtenlas en: https://developers.facebook.com
# ========================================
META_VERIFY_TOKEN=your_verify_token
META_APP_SECRET=
META_ACCESS_TOKEN=your_meta_access_token
META_BUSINESS_ID=your_business_id
META_BUSINESS_NAME=your_business_name
META_PHONE_NUMBER_ID=your_phone_number_id
META_PHONE_NUMBER=+57XXXXXXXXXX

